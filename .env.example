# Banco de dados PostgreSQL (Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Chave secreta para proteger o endpoint /api/setup-db
# Gere uma senha forte e passe no header: x-setup-secret: <valor>
SETUP_SECRET=troque_para_uma_senha_forte_aqui

# (Opcional) Chave de API para autenticar chamadas do frontend
# Se definida, todos os endpoints de escrita exigem o header: x-api-key: <valor>
API_SECRET_KEY=

# (Opcional) Chave secreta para proteger o cron de limpeza automática /api/cron-cleanup
# Deve ser cadastrada no painel da Vercel como CRON_SECRET. A Vercel envia automaticamente no header Authorization.
CRON_SECRET=

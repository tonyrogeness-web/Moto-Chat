{
  "version": 2,
  "routes": [
    { "src": "/api/setup-db", "dest": "/api/setup-db.js" },
    { "src": "/api/orders",   "dest": "/api/orders.js"   },
    { "src": "/api/accept",   "dest": "/api/accept.js"   },
    { "src": "/api/motoboy-report", "dest": "/api/motoboy-report.js" },
    { "src": "/api/_utils",   "status": 404, "headers": { "x-blocked": "internal" } },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/sw.js",         "dest": "/sw.js" },
    { "src": "/(.*)",         "dest": "/index.html" }
  ]
}

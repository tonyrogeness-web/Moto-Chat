{
  "name": "moto-chat",
  "version": "1.0.0",
  "description": "Moto-Chat Premium com Banco de Dados Neon e Vercel Serverless",
  "main": "index.html",
  "engines": {
    "node": ">=18.x"
  },
  "dependencies": {
    "pg": "^8.11.3"
  },
  "scripts": {
    "start": "node -e \"require('http').createServer((req,res)=>{require('fs').readFile('./index.html','utf8',(e,d)=>{res.writeHead(200,{'Content-Type':'text/html'});res.end(d)})}).listen(3000,()=>console.log('Local server at http://localhost:3000'))\""
  }
}
